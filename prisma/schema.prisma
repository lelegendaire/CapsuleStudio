generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  createdAt DateTime  @default(now())
  capsules  Capsule[]
}

model Capsule {
  id          String    @id @default(cuid())
  name        String
  description String?
  openDate    DateTime?
  visibility  String    @default("private")
  password    String?
  files       Json?
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
}
